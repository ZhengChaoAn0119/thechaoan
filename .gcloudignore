# Inherit all rules from .gitignore
#!include:.gitignore

# Git metadata
.git/
.gitignore

# Local dev / editor config
.claude/
.vscode/
.idea/
*.pem

# Build outputs (rebuilt in Cloud Build)
.next/
.contentlayer/
/out/
/build/

# Dependencies (reinstalled in Cloud Build)
node_modules/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment files
.env*

# OS artifacts
.DS_Store
Thumbs.db

# Documentation
README.md
CLAUDE.md
AGENTS.md
